# ─── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Firebase ─────────────────────────────────────────────
# Option 1: Paste the entire service-account JSON as a single-line string
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}
# Option 2: path to service-account file (used as fallback when FIREBASE_CREDENTIALS is unset)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=900        # seconds  (15 min)
JWT_REFRESH_EXPIRY=604800    # seconds  (7 days)

# ─── Cookies ──────────────────────────────────────────────
COOKIE_SECURE=true           # false in local dev

# ─── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourfrontend.vercel.app,http://localhost:5173

# ─── Email (Brevo) ────────────────────────────────────────
BREVO_API_KEY=xkeysib-your-brevo-key
MAIL_FROM=no-reply@yourapp.com
